# Site Configuration
NEXT_PUBLIC_SITE_URL=https://web3pay.example.com
NEXT_PUBLIC_SITE_NAME="Web3Pay"

# Wallet Connect
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# RPC URLs (Optional - for better performance)
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_key
NEXT_PUBLIC_INFURA_API_KEY=your_infura_key
NEXT_PUBLIC_ETHEREUM_RPC=https://eth-mainnet.alchemyapi.io/v2/your_key
NEXT_PUBLIC_POLYGON_RPC=https://polygon-mainnet.alchemyapi.io/v2/your_key
NEXT_PUBLIC_BSC_RPC=https://bsc-dataseed.binance.org/

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id

# API Configuration
NEXT_PUBLIC_API_URL=https://api.web3pay.example.com
API_SECRET_KEY=your_secret_key

# Database (if using)
DATABASE_URL=postgresql://user:password@localhost:5432/web3pay

# Authentication
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Email (if using)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Development
NODE_ENV=development
NEXT_PUBLIC_DEBUG=false
