# ─── Merchant Wallet Addresses ───────────────────────────────────────────────
# Payments are sent to THESE addresses — replace with your own receiving wallets.
# Leave a variable empty ("") to disable that chain entirely in the UI.
#
# To disable a chain: set its variable to empty, e.g.
#   NEXT_PUBLIC_MERCHANT_BTC_ADDRESS=
#
# To enable a chain: set its variable to a valid address for that network.

NEXT_PUBLIC_MERCHANT_ETH_ADDRESS=
NEXT_PUBLIC_MERCHANT_BTC_ADDRESS=
NEXT_PUBLIC_MERCHANT_SOL_ADDRESS=
NEXT_PUBLIC_MERCHANT_TRX_ADDRESS=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME="Web3Pay"

# Wallet Connect
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# RPC URLs (Optional - for better performance)
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_INFURA_API_KEY=
NEXT_PUBLIC_ETHEREUM_RPC=
NEXT_PUBLIC_POLYGON_RPC=
NEXT_PUBLIC_BSC_RPC=

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_HOTJAR_ID=

# API Configuration
NEXT_PUBLIC_API_URL=
API_SECRET_KEY=

# Database (if using)
DATABASE_URL=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Email (if using)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Development
NODE_ENV=development
NEXT_PUBLIC_DEBUG=false
